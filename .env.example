# Backend Configuration

# REQUIRED: Strong password for accessing the app
# Generate a strong password using: openssl rand -base64 32
BPAPP_PASSWORD=your-strong-password-here

# REQUIRED: Django secret key
# Generate using: openssl rand -base64 64
SECRET_KEY=your-secret-key-here

# Database Configuration (handled by Fly.io PostgreSQL addon)
DB_NAME=bpmonitor
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=pg.internal
DB_PORT=5432

# Django Settings
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,yourapp.fly.dev

# CORS Configuration (set to your frontend domain)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,https://yourapp.fly.dev

# Frontend Development (development only)
VITE_API_URL=http://localhost:8000/api
