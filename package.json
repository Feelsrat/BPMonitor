{
  "name": "bp-monitor",
  "version": "1.0.0",
  "description": "Blood Pressure Monitor App - Vercel + Vite",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node dev-server.js\" \"npm --prefix frontend run dev\" --names \"API,UI\" --prefix-colors \"cyan,magenta\"",
    "dev:api": "node dev-server.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "install:all": "npm install && npm --prefix api install && npm --prefix frontend install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
